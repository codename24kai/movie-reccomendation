# ============================================================
# MovieHub — Production Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit .env ke repository!
# ============================================================

# Flask
SECRET_KEY=ganti-dengan-string-acak-minimal-32-karakter
FLASK_ENV=production

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/movie_forum_db?appName=<appname>

# TMDB API
TMDB_API_KEY=masukkan-tmdb-api-key-anda

# Path dataset & model (sesuaikan dengan server)
DATA_DIR=./cleaned_data
MODELS_DIR=./models

# CORS: domain frontend production (pisahkan dengan koma jika lebih dari satu)
# Contoh: https://moviehub.vercel.app,https://www.moviehub.com
ALLOWED_ORIGINS=https://your-app.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
